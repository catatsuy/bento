{
  "extends": [
    "config:recommended"
  ],
  "minimumReleaseAge": "1 day",
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/.github/workflows/go.yml/"
      ],
      "datasourceTemplate": "golang-version",
      "depNameTemplate": "go",
      "matchStrings": [
        "go-version: \"?(?<currentValue>[0-9]*.[0-9]*.[0-9]*)\"?"
      ]
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/.github/workflows/security.yml/"
      ],
      "datasourceTemplate": "golang-version",
      "depNameTemplate": "go-security",
      "matchStrings": [
        "go-version: \"?(?<currentValue>[0-9]*.[0-9]*.[0-9]*)\"?"
      ]
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/.github/workflows/security.yml/"
      ],
      "datasourceTemplate": "go",
      "depNameTemplate": "golang.org/x/vuln",
      "matchStrings": [
        "golang.org/x/vuln/cmd/govulncheck@(?<currentValue>v[0-9]+\\.[0-9]+\\.[0-9]+)"
      ]
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/.github/workflows/release.yml/"
      ],
      "datasourceTemplate": "golang-version",
      "depNameTemplate": "go",
      "matchStrings": [
        "go-version: \"?(?<currentValue>[0-9]*.[0-9]*.[0-9]*)\"?"
      ]
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/osv-scanner.toml/"
      ],
      "datasourceTemplate": "golang-version",
      "depNameTemplate": "go-security",
      "matchStrings": [
        "GoVersionOverride = \"?(?<currentValue>[0-9]*.[0-9]*.[0-9]*)\"?"
      ]
    }
  ],
  "packageRules": [
    {
      "matchDepNames": [
        "go"
      ]
    },
    {
      "matchDepNames": [
        "go-security"
      ],
      "groupName": "go-version-security"
    }
  ],
  "postUpdateOptions": [
    "gomodTidy",
    "gomodUpdateImportPaths"
  ]
}
